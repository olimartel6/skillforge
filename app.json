{
  "expo": {
    "name": "Skilly",
    "slug": "skilly",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "skilly",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0b"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.olimartel6.skilly",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "SkillForge needs camera access to record your practice sessions for AI feedback.",
        "NSMicrophoneUsageDescription": "SkillForge needs microphone access to record audio during practice sessions.",
        "NSPhotoLibraryUsageDescription": "SkillForge needs photo library access to save your practice photos."
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.olimartel6.skilly",
      "adaptiveIcon": {
        "backgroundColor": "#0a0a0b",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "SkillForge needs camera access to record your practice sessions."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#FF6B35"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "SkillForge needs photo library access to save practice photos."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": ""
      }
    },
    "owner": "olimartel6"
  }
}
